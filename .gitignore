.DS_Store

# Build artifacts
dist/
build/
*.egg-info/
*.spec

# Python cache
__pycache__/
*.pyc
*.pyo
*.pyd

# Virtual environments
.venv/
venv/


# IDE
.vscode/
.idea/

# OS
Thumbs.db

# Temporary files
*.tmp
*.log

# AWS credentials (safety)
.aws/credentials
.aws/config

# Local environment files
.env
.env.local

# Claude Code settings
.claude/
CLAUDE.md

#Claude Code plugin settings
.claude-plugin

# Kiro settings (contains tokens)
.kiro/settings/mcp.json

# Local documentation and feedback
FEEDBACK.md

# Temporary test files
output.json
*.bak
test_*.py


guidance-docs/
parameters.json

# ccwb deployment config
source/.ccwb-config/

guidance-submission/
tests/
!source/tests/
assets/docs/planning

.pytest_cache/
.ruff_cache/
.coverage
.epcc

EPCC_*
PRs/
test_cognito_detection.py

# Development documentation (not for production)
TESTING_*.md
IMPLEMENTATION_SUMMARY.md
PARTITION_*.md
FEEDBACK.md
.claudeignore
.mcp.json

# Local POC/demo distributions and customer-scoped output bundles.
# Never commit these: they contain signed installers, signed URLs,
# platform zips and generated config.json specific to a tenant.
*-poc-dist/
*-poc/

# Ad-hoc scratch/fix workspaces inside source/ (duplicate trees used
# for one-off fixes). Keep them out of the package.
source/fix*/

# Developer-local profile/test dumps produced by `ccwb` wizards.
# These can contain Okta/Auth0/Azure domains, client IDs, VPC and
# subnet IDs from the developer's sandbox.
ccwb-test.json
ccwb-*-test.json

# Ad-hoc developer fix scripts at repo root.
/apply-fix*.sh
/ccwb-fix*.sh
